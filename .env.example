# Copy this file to ".env" for local development, and set the same variables
# in Railway → your service → Variables for production.

# Ravan (Agni) — the live web-call demo. RAVAN_API_KEY is a secret: never commit it.
RAVAN_API_KEY=your_ravan_api_key_here
RAVAN_AGENT_ID=your_demo_agent_id_here
# Optional override (defaults to the public Ravan endpoint):
# RAVAN_API_URL=https://api.ravan.ai/api/v1/calling/create-call

# Make.com webhook that receives contact + "talk to a human" requests.
# Defaults to your hook if left unset.
MAKE_WEBHOOK_URL=https://hook.us1.make.com/2duhuouszq919zesc4arpcfaarp2br9g
